Proceso CALCULAR_COMISIONES
	Escribir "BIENVENIDO A ESTE PROGRAMA QUE CALCULARA TUS INGRESOS"
	Escribir "DIGITE SU VENTA A"
	Leer A
	Escribir "DIGITE SU VENTA B"
	Leer B
	Escribir "DIGITE SU VENTA C"
	Leer C
	SUMA <- (A+B+C) 
	COMISIONES <- (SUMA * 0.10)
	TOTAL <- (COMISIONES + SUMA)
	Escribir " SUS INGRESOS EN TOTAL FUERON DE " , SUMA
	Escribir "Y CON LAS COMISIONES UN TOTAL DE " TOTAL
FinProceso
	
