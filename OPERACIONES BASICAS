Proceso OPERACIONES_BÁSICAS
	Escribir "DIGITE EL A "
	Leer A
	Escribir "DIGITE EL B"
	Leer B
	SUMA <- A + B
	RESTA <- A - B
	DIVISION <- A/B
	MULTIPLICACION <- A * B
	Escribir "LA SUMA DE ESTOS DOS VALORES ES " , SUMA 
	Escribir " LA RESTA DE ESTOS DOS VALORES ES " , RESTA 
	ESCRIBIR " LA DIVISION DE ESTOS DOS VALORES ES " , DIVISION  
	Escribir " LA MULTIPLICACION DE ESTOS DOS VALORES ES " , MULTIPLICACION
FinProceso
