//ESTE PROGRAMA INTERCAMBIA LOS VALORES DE A Y B
Proceso INTERCAMBIARVALORES
	Escribir "BIENVENIDO A ESTE PROGRAMA QUE SE ENCARGA DE "
	Escribir " INVERTIR LOS VALORES DE A Y B  INGRESE A"
	Leer A
	Escribir "INGRESAR VALOR DE B"
	Leer B
	//AQUI INVIERTO LOS VALORES Y USO AUX O SEA UNA VARIABLE EXTRA PARA QUE GUARDE EL VALOR ORIGINAL DE A
	AUX <- A
	A<- B
	B<- AUX
	Escribir " EL NUEVO VALOR DE A ES " , A
	Escribir " EL NUEVO VALOR DE B ES " , B
FinProceso
