Proceso EDAD
	//PROGRAMA QUE IDENTIFICA SI UNA PERSONA ES MAYOR O MENOR DE ESDAD
	Escribir " BIENVENIDO DIGITE SU NORMBRE"
	Leer NOMBRE 
	Escribir "DIGITE SU EDAD1"
	Leer EDAD1
		SI EDAD1>= 18 Entonces
			Escribir NOMBRE , " ES MAYOR DE EDAD"
		SiNo
			Escribir NOMBRE , " ES MENOR DE EDAD"
		FinSi
FinProceso
	
